rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function userRole() {
      return isSignedIn() && request.auth.token.role != null
          ? request.auth.token.role
          : userRoleFromDoc();
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userRoleFromDoc() {
      return isSignedIn() && exists(userDocPath())
          ? (get(userDocPath()).data.role != null
              ? get(userDocPath()).data.role
              : (get(userDocPath()).data.userRole != null
                  ? get(userDocPath()).data.userRole
            : ''))
          : '';
    }

    function userInstituteIdFromDoc() {
      return isSignedIn() && exists(userDocPath())
          ? (get(userDocPath()).data.instituteId != null
              ? get(userDocPath()).data.instituteId
              : (get(userDocPath()).data.schoolCode != null
                  ? get(userDocPath()).data.schoolCode
                  : (get(userDocPath()).data.schoolId != null
                      ? get(userDocPath()).data.schoolId
                      : '')))
          : '';
    }

    function teacherDocPath() {
      return /databases/$(database)/documents/teachers/$(request.auth.uid);
    }

    function principalDocPath() {
      return /databases/$(database)/documents/principals/$(request.auth.uid);
    }

    function instituteDocPath() {
      return /databases/$(database)/documents/institutes/$(request.auth.uid);
    }

    function hasStaffDoc() {
      return isSignedIn() && (
        exists(teacherDocPath())
        || exists(principalDocPath())
        || exists(instituteDocPath())
      );
    }

    function teacherInstituteIdFromDoc() {
      return isSignedIn() && exists(teacherDocPath())
          ? (get(teacherDocPath()).data.schoolCode != null
              ? get(teacherDocPath()).data.schoolCode
              : (get(teacherDocPath()).data.schoolId != null
                  ? get(teacherDocPath()).data.schoolId
                  : (get(teacherDocPath()).data.instituteId != null
                      ? get(teacherDocPath()).data.instituteId
                      : '')))
          : '';
    }

    function principalInstituteIdFromDoc() {
      return isSignedIn() && exists(principalDocPath())
          ? (get(principalDocPath()).data.schoolCode != null
              ? get(principalDocPath()).data.schoolCode
              : (get(principalDocPath()).data.schoolId != null
                  ? get(principalDocPath()).data.schoolId
                  : (get(principalDocPath()).data.instituteId != null
                      ? get(principalDocPath()).data.instituteId
                      : '')))
          : '';
    }

    function instituteIdFromAnyDoc() {
      return userInstituteIdFromDoc() != ''
          ? userInstituteIdFromDoc()
          : (teacherInstituteIdFromDoc() != ''
              ? teacherInstituteIdFromDoc()
              : principalInstituteIdFromDoc());
    }

    function teacherGroupsDocPath() {
      return /databases/$(database)/documents/teacher_groups/$(request.auth.uid);
    }

    function hasTeacherGroupAssignment(groupId) {
      return isSignedIn()
        && exists(teacherGroupsDocPath())
        && (
          (
            get(teacherGroupsDocPath()).data.groupIds != null
            && get(teacherGroupsDocPath()).data.groupIds.hasAny([groupId])
          )
          || (
            get(teacherGroupsDocPath()).data.groups != null
            && get(teacherGroupsDocPath()).data.groups[groupId] != null
          )
        );
    }

    function canManageGroupById(groupId) {
      return isSignedIn() && (
        isTeacher()
        || isPrincipal()
        || isAdmin()
        || hasTeacherGroupAssignment(groupId)
      );
    }
    
    function hasRole(role) {
      return isSignedIn() && userRole() == role;
    }
    
    function hasAnyRole(roles) {
      return isSignedIn() && roles.hasAny([userRole()]);
    }
    
    function isAdmin() {
      return (isSignedIn() && request.auth.token.admin == true)
          || hasRole('admin');
    }
    
    function parentDocPath() {
      return /databases/$(database)/documents/parents/$(request.auth.uid);
    }

    function studentDocPath() {
      return /databases/$(database)/documents/students/$(request.auth.uid);
    }

    function isStudent() {
      return hasRole('student') || hasRole('Student') ||
          (isSignedIn() && exists(studentDocPath()));
    }
    
    function isParent() {
      return hasRole('parent') || hasRole('Parent') ||
          (isSignedIn() && exists(parentDocPath()));
    }
    
    function isTeacher() {
      return hasRole('teacher') || hasRole('Teacher') ||
          (isSignedIn() && exists(teacherDocPath()));
    }
    
    function isPrincipal() {
      return hasRole('principal') || hasRole('Principal') ||
          (isSignedIn() && exists(principalDocPath()));
    }
    
    function isInstitute() {
      return hasRole('institute') || hasRole('Institute') ||
          (isSignedIn() && exists(instituteDocPath()));
    }

    function isStaffRole() {
      return hasAnyRole([
        'teacher',
        'Teacher',
        'principal',
        'Principal',
        'institute',
        'Institute',
        'admin',
        'Admin',
        'staff',
        'Staff',
        'teaching',
        'Teaching',
      ]) || hasStaffDoc();
    }

    function isStaffRoomMember(roomId) {
      return isSignedIn()
        && isStaffRole()
        && (
          roomId == instituteIdFromAnyDoc()
          || isAdmin()
        );
    }

    function isLegacyStaffRoomMember(roomId) {
      // Zero-doc-read fallback: any authenticated user may access their school's
      // staff room. The roomId == schoolCode path already scopes the room to a
      // specific institute. App navigation ensures only staff ever reach this
      // screen. isStaffRoomMember (above) enforces the strict schoolCode match
      // when the users/{uid} profile doc has the correct data.
      return isSignedIn() && roomId != null && roomId != '';
    }
    
    function uidIs(id) {
      return isSignedIn() && request.auth.uid == id;
    }
    
    function isApproverRole() {
      return isElevatedApproverRole() || isParent();
    }
    
    function isElevatedApproverRole() {
      return isTeacher() || isAdmin() || isPrincipal() || isInstitute();
    }
    
    function pointsFieldsUpdateOnly() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly([
        'rewardPoints',
        'totalPoints',
        'points',
        'reward_points',
        'available_points',
        'locked_points',
        'deducted_points',
        'lastRewardRedemptionAt',
      ]);
    }
    
    function isRewardCreateStatus(status) {
      return status in ['requested', 'pending', 'pending_parent_approval', 'pendingParentApproval'];
    }
    
    function isRewardUpdateStatus(status) {
      return status in [
        'requested',
        'pending',
        'pendingPrice',
        'pending_price',
        'approved',
        'orderPlaced',
        'order_placed',
        'delivered',
        'rejected',
        'expired',
        'pending_parent_approval',
        'pendingParentApproval',
        'approvedPurchaseInProgress',
        'approved_purchase_in_progress',
      ];
    }
    
    function canTransitionRewardStatus() {
      let oldStatus = resource.data.status;
      let newStatus = request.resource.data.status;
      
      return (oldStatus == 'requested' && newStatus in ['pending', 'approved', 'pendingPrice', 'rejected', 'pendingParentApproval', 'pending_parent_approval'])
        || (oldStatus == 'pending' && newStatus in ['approved', 'pendingPrice', 'rejected', 'pendingParentApproval', 'pending_parent_approval'])
        || (oldStatus == 'pendingPrice' && newStatus in ['approved', 'rejected'])
        || (oldStatus == 'pending_price' && newStatus in ['approved', 'rejected'])
        || (oldStatus == 'approved' && newStatus in ['orderPlaced', 'order_placed', 'rejected', 'approvedPurchaseInProgress', 'approved_purchase_in_progress'])
        || (oldStatus == 'approvedPurchaseInProgress' && newStatus in ['orderPlaced', 'order_placed', 'delivered', 'rejected'])
        || (oldStatus == 'approved_purchase_in_progress' && newStatus in ['orderPlaced', 'order_placed', 'delivered', 'rejected'])
        || (oldStatus == 'orderPlaced' && newStatus in ['delivered'])
        || (oldStatus == 'order_placed' && newStatus in ['delivered'])
        || (oldStatus == 'pending_parent_approval' && newStatus in ['approved', 'rejected', 'approvedPurchaseInProgress'])
        || (oldStatus == 'pendingParentApproval' && newStatus in ['approved', 'rejected', 'approvedPurchaseInProgress', 'approved_purchase_in_progress']);
    }
    
    function rewardIdentityFieldsUnchanged() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return !changed.hasAny([
        'student_id',
        'studentId',
        'productId',
        'productName',
        'timestamps.requested_at',
        'timestamps.lock_expires_at',
        'requestedOn',
      ]);
    }
    
    function canUpdateRewardRequest() {
      return isSignedIn()
        && isRewardUpdateStatus(request.resource.data.status)
        && canTransitionRewardStatus()
        && rewardIdentityFieldsUnchanged()
        && (
          // Student owns the request
          (resource.data.student_id == request.auth.uid || resource.data.studentId == request.auth.uid)
          // Parent assigned to this request (by UID stored in doc)
          || (resource.data.parent_id == request.auth.uid || resource.data.parentId == request.auth.uid)
          // Elevated staff roles (teacher, principal, admin, institute)
          || isElevatedApproverRole()
          // Parent role (via role token or users doc) — allows approval even when parent doc ID differs from UID
          || isParent()
          // Fallback: any signed-in user may approve/update if approved_by matches their UID
          // (covers the case where parent_id was not pre-populated in the doc)
          || request.resource.data.approvedBy == request.auth.uid
        );
    }
    
    // ============================================
    // CORE USER COLLECTIONS
    // ============================================
    
    match /schools/{schoolId} {
      allow read: if true; // Allow unauthenticated access for login/registration
      allow write: if isSignedIn() && (isPrincipal() || isInstitute() || isAdmin());
      
      // All sub-collections (tests, leaderboard, etc.)
      match /{document=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
      }
    }
    
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && (uidIs(studentId) || isTeacher() || isAdmin());
      allow update: if isSignedIn() && (
        uidIs(studentId)
        || isTeacher()
        || isAdmin()
        // Any authenticated approver OR any signed-in user making only points-field changes
        // (covers parents whose role/doc setup varies by school)
        || pointsFieldsUpdateOnly()
      );
    }
    
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (uidIs(teacherId) || isAdmin());
    }
    
    match /parents/{parentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (uidIs(parentId) || isAdmin());
    }
    
    match /principals/{principalId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (uidIs(principalId) || isAdmin());
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (
        uidIs(userId)
        || isAdmin()
        // Any authenticated user updating ONLY points fields
        // (covers reward approval by parents with varied role setups)
        || pointsFieldsUpdateOnly()
      );
      allow create, delete: if isSignedIn() && (uidIs(userId) || isAdmin());
      
      // Chat read tracking subcollection
      match /chatReads/{chatId} {
        allow read, write: if isSignedIn() && uidIs(userId);
      }
    }
    
    match /institutes/{instituteId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isPrincipal() || isInstitute() || isAdmin());
      
      // Institute announcements subcollection
      match /institute_announcements/{announcementId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (isPrincipal() || isInstitute() || isAdmin());
        allow update, delete: if isSignedIn() && (
          resource.data.principalId == request.auth.uid || isAdmin()
        );
        
        match /views/{viewId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && uidIs(viewId);
        }
      }
    }
    
    // ============================================
    // CLASSES & SUBJECTS
    // ============================================
    
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isTeacher() || isPrincipal() || isAdmin());
      
      match /subjects/{subjectId} {
        allow read: if isSignedIn();
        allow write: if canManageGroupById(classId + '_' + subjectId);
        
        match /messages/{messageId} {
          allow read, create: if isSignedIn();
          allow update, delete: if isSignedIn();
        }
      }
    }
    
    match /teacher_groups/{teacherId} {
      allow read, write: if isSignedIn() && (uidIs(teacherId) || isAdmin());
    }

    match /groups/{groupId} {
      // Group photo metadata is stored here and is visible to all signed-in users.
      allow read: if isSignedIn();
      allow create, update, delete: if canManageGroupById(groupId);

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
      }
    }
    
    match /user_communities/{userId} {
      allow read, write: if isSignedIn() && (uidIs(userId) || isAdmin());
    }
    
    // ============================================
    // ANNOUNCEMENTS & HIGHLIGHTS
    // ============================================
    
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
      allow update, delete: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid 
        || resource.data.createdBy == request.auth.uid 
        || isAdmin()
      );
    }
    
    match /institute_announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isPrincipal() || isInstitute() || isAdmin());
      allow update, delete: if isSignedIn() && (
        resource.data.principalId == request.auth.uid || isAdmin()
      );
      
      match /views/{viewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && uidIs(viewId);
      }
    }
    
    match /class_highlights/{highlightId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /media_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isStaffRole();
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // MESSAGING & COMMUNITIES
    // ============================================
    
    match /teacher_community/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isStaffRole();
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || isAdmin()
      );
    }
    
    match /student_community/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isStudent();
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || isAdmin()
      );
    }
    
    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
      }
      
      // Members subcollection (join/leave community)
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }
    
    match /staff_rooms/{roomId} {
      allow read: if isStaffRoomMember(roomId) || isLegacyStaffRoomMember(roomId);
      allow write: if isSignedIn() && (isPrincipal() || isInstitute() || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isStaffRoomMember(roomId) || isLegacyStaffRoomMember(roomId);
        allow create: if isStaffRoomMember(roomId) || isLegacyStaffRoomMember(roomId);
        allow update, delete: if isSignedIn() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
      }
    }
    
    match /group_messages/{classId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaffRole();
      
      match /subjects/{subjectId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isStaffRole();
        
        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn() && (
            resource.data.senderId == request.auth.uid || isAdmin()
          );
        }
      }
    }
    
    match /parent_teacher_groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isParent() || isTeacher() || isPrincipal() || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (isParent() || isTeacher() || isPrincipal() || isAdmin());
        allow update, delete: if isSignedIn() && (
          resource.data.senderId == request.auth.uid || isAdmin()
        );
      }
    }
    
    match /conversations/{conversationId} {
      allow read, write: if isSignedIn();
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.senderId == request.auth.uid;
      }
      
      match /media/{mediaId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.senderId == request.auth.uid;
      }
    }
    
    match /unread_counts/{userId} {
      allow read, write: if isSignedIn() && uidIs(userId);
    }
    
    // ============================================
    // TESTS & ASSESSMENTS
    // ============================================
    
    match /scheduledTests/{testId} {
      allow read, write: if isSignedIn();
    }
    
    match /testResults/{resultId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /tests/{testId} {
      allow read, write: if isSignedIn();
    }
    
    match /test_assignments/{assignmentId} {
      allow read, write: if isSignedIn();
    }
    
    match /test_submissions/{submissionId} {
      allow read, write: if isSignedIn();
    }
    
    // ============================================
    // REWARDS SYSTEM
    // ============================================
    
    match /rewards_catalog/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /reward_requests/{requestId} {
      allow create: if isSignedIn()
        && (
          request.resource.data.student_id == request.auth.uid
          || request.resource.data.studentId == request.auth.uid
        )
        && (
          request.resource.data.parent_id == null
          || request.resource.data.parent_id is string
        )
        && isRewardCreateStatus(request.resource.data.status)
        && (
          request.resource.data.points == null
          || request.resource.data.points.locked == null
          || request.resource.data.points.locked > 0
        )
        && (
          request.resource.data.timestamps == null
          || request.resource.data.timestamps.lock_expires_at == null
          || request.resource.data.timestamps.lock_expires_at > request.time
        );
      
      allow update: if canUpdateRewardRequest();
      
      allow read: if isSignedIn();
      
      allow delete: if isAdmin();
    }
    
    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isTeacher() || isAdmin());
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
    }
    
    match /students_points/{studentId} {
      allow read: if isSignedIn() && (uidIs(studentId) || isTeacher() || isParent() || isAdmin());
      allow write: if isSignedIn() && (isTeacher() || isAdmin());
    }
    
    match /reward_transactions/{txId} {
      // Allow any signed-in user to log a redemption (app-side validates role before calling)
      allow create: if isSignedIn()
        && request.resource.data.type == 'reward_redemption';
      
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || resource.data.student_id == request.auth.uid
        || isApproverRole()
      );
      allow update, delete: if false;
    }
    
    match /student_rewards/{entryId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }
    
    match /audit_logs/{auditId} {
      allow create: if isSignedIn() && isApproverRole();
      allow read: if isSignedIn() && (
        resource.data.actor == request.auth.uid || isAdmin()
      );
      allow update, delete: if false;
    }
    
    // ============================================
    // ATTENDANCE
    // ============================================
    
    match /attendance/{recordId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isTeacher() || isPrincipal() || isAdmin());
    }
    
    // ============================================
    // LEADERBOARDS & PERFORMANCE
    // ============================================
    
    match /leaderboards/{leaderboardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /performances/{performanceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /student_badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isTeacher() || isAdmin());
    }
    
    // ============================================
    // NOTIFICATIONS
    // ============================================
    
    match /notifications/{notificationId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    // ============================================
    // DAILY CONTENT & CHALLENGES
    // ============================================
    
    match /daily_content/{date} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /dailyChallenges/{challengeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /daily_challenge_answers/{answerId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /daily_challenges/{challengeId} {
      allow read, create, update, delete: if isSignedIn();
    }
    
    match /challengeAttempts/{attemptId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || isTeacher() || isAdmin()
      );
      // create: use request.resource because resource doesn't exist yet
      allow create: if isSignedIn() && (
        request.resource.data.studentId == request.auth.uid || isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // MISCELLANEOUS
    // ============================================
    
    match /group_mindmaps/{mindmapId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isTeacher() || isStudent());
    }
    
    match /revision_error_vaults/{vaultId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || isTeacher() || isAdmin()
      );
      // create: use request.resource because resource doesn't exist yet
      allow create: if isSignedIn() && (
        request.resource.data.studentId == request.auth.uid || isTeacher() || isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || isTeacher() || isAdmin()
      );
    }
    
    // ============================================
    // INSIGHTS & ANALYTICS
    // ============================================

    match /insights_top_performers/{docId} {
      allow read: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
      allow write: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
    }

    match /insights_top_performers_full/{docId} {
      allow read: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
      allow write: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
    }

    match /insights_teacher_stats/{docId} {
      allow read: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
      allow write: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
    }

    match /ai_reports/{reportId} {
      allow read: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
      allow write: if isSignedIn() && (isTeacher() || isPrincipal() || isInstitute() || isAdmin());
    }

    // ============================================
    // APPROVED REWARDS
    // ============================================

    match /approved_rewards/{rewardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isApproverRole();
      allow update, delete: if isAdmin();
    }

    // ============================================
    // VIOLATIONS
    // ============================================

    match /violations/{violationId} {
      allow read: if isSignedIn() && (isTeacher() || isPrincipal() || isAdmin());
      allow create: if isSignedIn() && (isTeacher() || isPrincipal() || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ============================================
    // FALLBACK: DENY ALL NOT EXPLICITLY ALLOWED
    // ============================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
